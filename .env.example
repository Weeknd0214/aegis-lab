# aegis-lab — Docker Compose 环境变量

AS_PLATFORM_PORT=8788
AS_DB_PORT=5433
AS_REDIS_PORT=6380
CVAT_PORT=8081
CVAT_HOST=http://aegis-lab-cvat-server:8080
CVAT_PUBLIC_URL=http://127.0.0.1:8081

# 使用 GHCR 预构建镜像（推送后生效）
# AEGIS_IMAGE_TAG=latest
# AEGIS_PLATFORM_IMAGE=ghcr.io/weeknd0214/aegis-lab-platform:latest
# AEGIS_CVAT_IMAGE=ghcr.io/weeknd0214/aegis-lab-cvat-server:latest

# AS_WORKSPACE_ROOT=/path/to/workspace
AS_FLEET_MAP_ENABLED=1
AS_FLEET_MOCK_SEED=1
AS_MAP_TILE_PROVIDER=gaode
